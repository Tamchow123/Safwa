# Safwa server environment (Phase 15). Copy to .env.local for local
# development; never commit .env.local. See docs/DEPLOYMENT.md §2.

# PostgreSQL connection string (postgres:// or postgresql://). Local docker
# compose default matches docker/init-test-db.sql + compose.yaml.
DATABASE_URL=postgres://safwa:safwa_dev_only@localhost:5432/safwa_dev

# Better Auth session/token signing secret. Generate with:
#   pnpm exec auth secret
# Required to be >=32 characters in production.
BETTER_AUTH_SECRET=

# Canonical origin Better Auth issues callback/verification links against.
BETTER_AUTH_URL=http://localhost:3000

# Public app origin (client bundles). Must match BETTER_AUTH_URL's origin.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth feature flag / rollback kill-switch. false = auth routes report a safe
# "unavailable" state; guest study is unaffected either way.
AUTH_ENABLED=true

# console-file (default, local/dev/test — no external email sends) | resend
# (preview/production).
EMAIL_TRANSPORT=console-file

# Required when EMAIL_TRANSPORT=resend.
RESEND_API_KEY=
EMAIL_FROM=

# Directory the console-file transport writes messages to (gitignored).
EMAIL_OUTBOX_DIR=.local/email-outbox

# Directory containing the server-only content manifests
# (content-server/release-registry.json + releases/<id>/{validation,assessment,checksums}.json).
CONTENT_SERVER_DIR=content-server

# Escape hatch for preview deployments that build with NODE_ENV=production
# but intentionally still want the console/file transport. Leave unset
# everywhere else — real production must use resend.
ALLOW_DEV_EMAIL_TRANSPORT_IN_PRODUCTION=false

# Applied uniformly to every sensitive auth endpoint's rate-limit rule
# (sign-up/sign-in/send-verification-email/request-password-reset/
# reset-password/delete-user). Lower these in integration tests for a
# fast, deterministic trigger — never disable rate limiting outright.
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX=5
